# X API credentials — https://developer.x.com/en/portal/dashboard
# App permissions: Read and Write
# Enable OAuth 1.0a with Read + Write for the bot account

X_API_KEY=your_api_key
X_API_SECRET=your_api_secret
X_ACCESS_TOKEN=bot_account_access_token
X_ACCESS_TOKEN_SECRET=bot_account_access_token_secret

# Bot @handle (without @) — used to parse mentions
BOT_USERNAME=MonEx

# Poll interval for new mentions (ms). POC default: 45 seconds
POLL_MS=45000

# Activity server port (npm run server)
PORT=3001

# Set to 1 to poll X mentions into activity log (no replies)
ENABLE_X_POLL=0

# Starting monballs for first-time X users (POC only — no DB yet)
STARTING_MONBALLS=50

# Site link in catch replies
GAME_URL=https://github.com/jericddd/MonEx
